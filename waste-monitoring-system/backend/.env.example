# Backend development environment
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=waste_monitoring_system

# Admin login for local development
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Comma-separated frontend/admin origins allowed to call backend
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8083,http://127.0.0.1:8083,http://localhost:3000,http://127.0.0.1:3000

# Gmail SMTP (forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-gmail-app-password
SMTP_FROM=your-gmail@gmail.com
SMTP_FROM_NAME=EcoTrack Waste Monitoring
# Optional Expo push API access token
EXPO_PUSH_ACCESS_TOKEN=

# Optional: Google token audience validation on backend
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

