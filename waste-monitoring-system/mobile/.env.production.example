# Mobile production environment template
EXPO_PUBLIC_API_URL="https://api.yourdomain.com"
# Optional fallback for LAN-based development only:
# EXPO_PUBLIC_API_HOST="192.168.1.10"

# Google OAuth client IDs
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="your-android-client-id.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="your-ios-client-id.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
# Only required for Expo Go; leave empty for dev build / production binaries
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=""

# Google Maps API keys injected by app.config.js at build time
GOOGLE_MAPS_ANDROID_API_KEY="your-android-maps-api-key"
GOOGLE_MAPS_IOS_API_KEY="your-ios-maps-api-key"

# Optional explicit Firebase config file paths (if not set, defaults are used):
# - ./google-services.json (Android)
# - ./GoogleService-Info.plist (iOS)
GOOGLE_SERVICES_JSON_PATH="./google-services.json"
GOOGLE_SERVICE_INFO_PLIST_PATH="./GoogleService-Info.plist"
