{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --port 8081",
    "start:dev-client": "expo start --dev-client --port 8083 --tunnel",
    "android": "expo start --android",
    "android:dev": "expo run:android --device",
    "ios": "expo start --ios",
    "ios:dev": "expo run:ios --device",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "build:android:development": "npx eas-cli build --platform android --profile development",
    "build:ios:development": "npx eas-cli build --platform ios --profile development"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "expo": "^54.0.0",
    "expo-dev-client": "~6.0.16",
    "expo-image-picker": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "socket.io-client": "^4.8.1"
  }
}
